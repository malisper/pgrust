# Data-driven variant -> struct mapping for the central `node_tree::Node` enum
# generated by build.rs (the analogue of gen_node_support.pl's central
# artifacts). One `T_tag  fully::qualified::StructPath` line per CONVERTED leaf
# node family. Variant order follows nodetags.h numeric-tag order (ABI order),
# resolved + sorted in build.rs; the discriminant/tag value is read from
# `../pgrust/postgres-18.3/src/backend/nodes/nodetags.h`.
#
# This is a PARTIAL enum over the converted-leaf subset (Value nodes, bitmapset,
# list). It compiles + dispatches today and grows as more node families convert
# (just add lines). Lifetime-parameterized structs are flagged in the third
# column with `mcx` (so the generator threads `<'mcx>` / re-homes onto `'dst`);
# lifetime-free leaves use `-`.
#
# tag            struct path                    lifetime

# --- bitmapset (nodes/bitmapset.h), custom_copy_equal ---
T_Bitmapset      crate::bitmapset::Bitmapset    mcx

# --- Value nodes (nodes/value.h) ---
T_Integer        crate::value::Integer          -
T_Float          crate::value::Float            mcx
T_Boolean        crate::value::Boolean          -
T_String         crate::value::StringNode       mcx
T_BitString      crate::value::BitString        mcx

# --- List (nodes/pg_list.h), special copy/equal. The four list flavours are ONE
#     struct (the `r#type` tag selects the flavour, exactly as in C); T_List is
#     the carrier variant. IntList/OidList/XidList are the same struct value with
#     a different `r#type`, so they do not need their own enum variant.
T_List           crate::list::List              mcx
