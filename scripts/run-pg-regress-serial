#!/usr/bin/env bash
# Run PostgreSQL's regression SQL files serially against one pgrust instance.

set -euo pipefail

usage() {
    code="${1:-2}"
    cat <<'EOF'
usage: scripts/run-pg-regress-serial [test names...]

Required environment:
  PG_SRC       PostgreSQL 18.3 source tree
  PG_INSTALL   PostgreSQL 18.3 C install prefix

Optional environment:
  PGRUST_BIN   pgrust postgres binary (default: target/release/postgres)
  PGPORT       port for the temp postmaster (default: 55433)
  OUTDIR       output directory (default: temp dir)
  STOP_AFTER   stop after this regression test name, for debugging
EOF
    exit "$code"
}

case "${1:-}" in
    --help|-h) usage 0 ;;
esac
repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

if [ -z "${PG_SRC:-}" ]; then
    echo "set PG_SRC to a PostgreSQL 18.3 source tree" >&2
    exit 1
fi
if [ -z "${PG_INSTALL:-}" ]; then
    echo "set PG_INSTALL to a PostgreSQL 18.3 C install prefix" >&2
    exit 1
fi

PG_SRC=$(CDPATH= cd -- "$PG_SRC" && pwd)
PG_INSTALL=$(CDPATH= cd -- "$PG_INSTALL" && pwd)
REGRESS="$PG_SRC/src/test/regress"
EXP="$REGRESS/expected"
SQL="$REGRESS/sql"
PG_LIBDIR="$PG_INSTALL/lib/postgresql"
PGRUST_BIN="${PGRUST_BIN:-$repo_root/target/release/postgres}"

if [ ! -d "$SQL" ] || [ ! -d "$EXP" ]; then
    echo "PostgreSQL regression files not found under $REGRESS" >&2
    exit 1
fi
for tool in initdb psql createdb; do
    if [ ! -x "$PG_INSTALL/bin/$tool" ]; then
        echo "PG_INSTALL must contain bin/$tool" >&2
        exit 1
    fi
done
if [ ! -x "$PGRUST_BIN" ]; then
    echo "pgrust postgres not found at $PGRUST_BIN; run: cargo build --release --bin postgres" >&2
    exit 1
fi

tmpbase=${TMPDIR:-/tmp}
tmpbase=${tmpbase%/}
OUTDIR="${OUTDIR:-$(mktemp -d "$tmpbase/pgrust_pg_regress_serial.XXXXXX")}"
DATADIR="$OUTDIR/data"
SOCK="$OUTDIR/sock"
STATUS="$OUTDIR/_status.tsv"
PM_LOG="$OUTDIR/postmaster.log"
PORT="${PGPORT:-55433}"

mkdir -p "$OUTDIR" "$SOCK"
mkdir -p "$OUTDIR/results"
: > "$STATUS"

if [ -z "${PG_DLSUFFIX:-}" ]; then
    case "$(uname -s)" in
        Darwin) PG_DLSUFFIX=.dylib ;;
        *) PG_DLSUFFIX=.so ;;
    esac
fi
export PG_ABS_SRCDIR="$REGRESS" PG_LIBDIR="$PG_LIBDIR" PG_DLSUFFIX
export PGTZ="${PGTZ:-America/Los_Angeles}"
export PGDATESTYLE="${PGDATESTYLE:-Postgres, MDY}"
export LANG="${LANG:-C}"
export LC_MESSAGES="${LC_MESSAGES:-C}"
export PGOPTIONS="${PGOPTIONS:--c intervalstyle=postgres_verbose}"
export RUST_MIN_STACK="${RUST_MIN_STACK:-33554432}"
unset LC_ALL LC_COLLATE LC_CTYPE LC_MONETARY LC_NUMERIC LC_TIME LANGUAGE

echo "regression output: $OUTDIR" >&2

"$PG_INSTALL/bin/initdb" -D "$DATADIR" --no-locale --encoding=UTF8 -U postgres >"$OUTDIR/initdb.log" 2>&1

ulimit -s 65520 2>/dev/null || true
"$PGRUST_BIN" -D "$DATADIR" -F -c listen_addresses= -k "$SOCK" -p "$PORT" \
    -c io_method=sync -c max_stack_depth=60000 \
    -c checkpoint_timeout=3600 -c autovacuum=on \
    -c max_logical_replication_workers=0 >"$PM_LOG" 2>&1 &
pm=$!

cleanup() {
    if kill -0 "$pm" 2>/dev/null; then
        kill "$pm" 2>/dev/null || true
        for _ in $(seq 1 50); do
            kill -0 "$pm" 2>/dev/null || return 0
            sleep 0.1
        done
        kill -9 "$pm" 2>/dev/null || true
    fi
}
trap cleanup EXIT

booted=no
for _ in $(seq 1 160); do
    if "$PG_INSTALL/bin/psql" -h "$SOCK" -p "$PORT" -U postgres -d postgres -c 'SELECT 1' >/dev/null 2>&1; then
        booted=yes
        break
    fi
    sleep 0.5
done
[ "$booted" = yes ] || {
    echo "postmaster did not start; see $PM_LOG" >&2
    exit 1
}

"$PG_INSTALL/bin/createdb" -h "$SOCK" -p "$PORT" -U postgres regression

if [ "$#" -gt 0 ]; then
    printf '%s\n' "$@" > "$OUTDIR/_order.txt"
else
    grep '^test:' "$REGRESS/parallel_schedule" |
        sed 's/^test:[[:space:]]*//' |
        tr ' ' '\n' |
        grep -v '^$' > "$OUTDIR/_order.txt"
fi

while IFS= read -r f; do
    [ -f "$SQL/$f.sql" ] || {
        echo "missing SQL file for test: $f" >&2
        exit 1
    }

    out="$OUTDIR/$f.out"
    set +e
    "$PG_INSTALL/bin/psql" -h "$SOCK" -p "$PORT" -U postgres -d regression \
        -X -a -q \
        -v HIDE_TABLEAM=on \
        -v HIDE_TOAST_COMPRESSION=on \
        -v "abs_srcdir=$REGRESS" \
        -v "abs_builddir=$OUTDIR" \
        -v "libdir=$PG_LIBDIR" \
        < "$SQL/$f.sql" > "$out" 2>&1
    rc=$?
    "$PG_INSTALL/bin/psql" -h "$SOCK" -p "$PORT" -U postgres -d postgres -c 'SELECT 1' >/dev/null 2>&1
    alive=$?
    set -e

    best="$EXP/$f.out"
    bl=999999
    for ef in "$EXP/$f.out" "$EXP/${f}_1.out" "$EXP/${f}_2.out"; do
        [ -f "$ef" ] || continue
        dl=$(set +o pipefail; diff "$out" "$ef" 2>/dev/null | wc -l | tr -d ' ')
        if [ "$dl" -lt "$bl" ]; then
            bl=$dl
            best="$ef"
        fi
    done

    if [ "$alive" -ne 0 ]; then
        status=CRASHED
    elif [ "$rc" -ne 0 ]; then
        status=PSQL_FAIL
    elif [ "$bl" -eq 0 ]; then
        status=PASS
    else
        status=FAIL
    fi

    printf '%s\t%s\t%d\t%s\n' "$f" "$status" "$bl" "$best" | tee -a "$STATUS"
    [ "${STOP_AFTER:-}" = "$f" ] && break
done < "$OUTDIR/_order.txt"

awk -F'\t' '{c[$2]++} END{printf "\nPASS=%d FAIL=%d PSQL_FAIL=%d CRASHED=%d\n", c["PASS"], c["FAIL"], c["PSQL_FAIL"], c["CRASHED"]}' "$STATUS"

if awk -F'\t' '$2!="PASS"{bad=1} END{exit bad ? 0 : 1}' "$STATUS"; then
    exit 1
fi
