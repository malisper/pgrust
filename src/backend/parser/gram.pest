type_name = { (qualified_known_base_type_name | known_base_type_name | named_type_name) ~ type_array_suffix* }
known_type_name = { known_base_type_name ~ type_array_suffix* }
qualified_known_base_type_name = { simple_identifier ~ "." ~ known_base_type_name }
known_base_type_name = { array_type_alias | internal_char_type | kw_record | kw_int2 | kw_smallint | kw_int4 | kw_int | kw_integer | kw_int8 | kw_bigint | kw_oid | kw_name | date_type | time_type | timestamp_type | interval_type | varbit_type | bit_type | kw_bytea | kw_uuid | kw_inet | kw_cidr | kw_macaddr8 | kw_macaddr | kw_money | kw_float4 | kw_real | kw_float8 | double_precision_type | numeric_type | kw_text | kw_refcursor | kw_bool | kw_boolean | kw_point | kw_lseg | kw_path | kw_box | kw_polygon | kw_line | kw_circle | kw_json | kw_jsonb | kw_jsonpath | kw_xml | kw_tsvector | kw_tsquery | kw_regproc | kw_regclass | kw_regconfig | kw_regdictionary | kw_regoper | kw_regoperator | kw_regprocedure | kw_regcollation | kw_pg_lsn | character_varying_type | varchar_type | char_type }
named_type_name = { identifier ~ named_type_typmod? }
named_type_typmod = { "(" ~ signed_integer ~ ("," ~ signed_integer)* ~ ")" }
array_type_alias = @{ "_" ~ ( "int2" | "smallint" | "int4" | "int" | "integer" | "int8" | "bigint" | "oid" | "name" | "text" | "refcursor" | "bool" | "boolean" | "bytea" | "uuid" | "inet" | "cidr" | "macaddr8" | "macaddr" | "money" | "float4" | "real" | "float8" | "timestamp" | "date" | "time" | "timetz" | "timestamptz" | "json" | "jsonb" | "jsonpath" | "xml" ) ~ keyword_end }
internal_char_type = @{ ^"\"char\"" }
type_array_suffix = { array_suffix | array_decl_suffix }
array_decl_suffix = { kw_array ~ array_suffix+ }
array_suffix = { "[" ~ integer? ~ "]" }
double_precision_type = { kw_double ~ kw_precision }
numeric_type = { (kw_numeric | kw_decimal) ~ ("(" ~ integer ~ ("," ~ signed_integer)? ~ ")")? }
date_type = { kw_date }
time_type = { (kw_timetz ~ ("(" ~ integer ~ ")")?) | (kw_time ~ ("(" ~ integer ~ ")")? ~ ((kw_with ~ kw_time ~ kw_zone) | (kw_without ~ kw_time ~ kw_zone))?) }
timestamp_type = { (kw_timestamptz ~ ("(" ~ integer ~ ")")?) | (kw_timestamp ~ ("(" ~ integer ~ ")")? ~ ((kw_with ~ kw_time ~ kw_zone) | (kw_without ~ kw_time ~ kw_zone))?) }
interval_type = { kw_interval ~ ("(" ~ integer ~ ")")? }
bit_type = { kw_bit ~ ("(" ~ integer ~ ")")? }
varbit_type = { (kw_varbit ~ ("(" ~ integer ~ ")")?) | (kw_bit ~ kw_varying ~ ("(" ~ integer ~ ")")?) }
char_type = { (kw_char | kw_character) ~ ("(" ~ integer ~ ")")? }
varchar_type = { kw_varchar ~ ("(" ~ integer ~ ")")? }
character_varying_type = { kw_character ~ kw_varying ~ ("(" ~ integer ~ ")")? }

assignment = { assignment_target ~ "=" ~ expr }
assignment_target_list = { assignment_target ~ ("," ~ assignment_target)* }
assignment_target = { identifier ~ assignment_target_suffix* }
assignment_target_suffix = { subscript_suffix | field_select_suffix }

expr = { or_expr }
or_expr = { and_expr ~ (kw_or ~ and_expr)* }
and_expr = { not_expr ~ (kw_and ~ not_expr)* }
not_expr = { kw_not ~ not_expr | cmp_expr }
cmp_expr = { json_access_expr ~ (is_normalized_suffix | is_document_suffix | null_predicate_suffix | overlaps_suffix | between_suffix | in_expr_list_suffix | in_subquery_suffix | quantified_suffix | quantified_like_suffix | quantified_similar_suffix | like_suffix | similar_suffix | comp_op ~ cmp_expr)? }
b_expr = { json_access_expr ~ (is_document_suffix | is_not_distinct_suffix | is_distinct_suffix | comp_op ~ json_access_expr)? }
json_access_expr = { concat_expr ~ (json_access_op ~ concat_expr)* }
concat_expr = { add_expr ~ (concat_op ~ add_expr)* }
add_expr = { bit_expr ~ (add_op ~ bit_expr)* }
bit_expr = { shift_expr ~ (bit_op ~ shift_expr)* }
shift_expr = { mul_expr ~ (shift_op ~ mul_expr)* }
mul_expr = { pow_expr ~ (mul_op ~ pow_expr)* }
pow_expr = { postfix_expr ~ (pow_op ~ postfix_expr)* }
concat_op = { "||" }
add_op = { "+" | neg_add_op }
neg_add_op = @{ "-" ~ !("|" | ">") }
bit_op = { amp_bit_op | pipe_bit_op | hash_bit_op }
amp_bit_op = @{ "&" ~ !("&" | "<" | ">") }
pipe_bit_op = @{ "|" ~ !("|" | "&" | ">" | "/") }
hash_bit_op = @{ "#" ~ !("#" | ">") }
shift_op = { left_shift_op | right_shift_op }
left_shift_op = @{ "<<" ~ !("|" | "=") }
right_shift_op = @{ ">>" ~ !"=" }
mul_op = { "*" | "/" | "%" }
pow_op = { "^" ~ !"@" }
null_predicate_suffix = { is_not_distinct_suffix | is_distinct_suffix | is_not_unknown_suffix | is_unknown_suffix | is_not_true_suffix | is_true_suffix | is_not_false_suffix | is_false_suffix | is_not_null_suffix | is_null_suffix | notnull_suffix | isnull_suffix }
between_suffix = { kw_not? ~ kw_between ~ kw_symmetric? ~ concat_expr ~ kw_and ~ concat_expr }
overlaps_suffix = { kw_overlaps ~ implicit_row_expr }
is_null_suffix = { kw_is ~ kw_null }
is_not_null_suffix = { kw_is ~ kw_not ~ kw_null }
isnull_suffix = { kw_isnull }
notnull_suffix = { kw_notnull }
is_true_suffix = { kw_is ~ kw_true }
is_not_true_suffix = { kw_is ~ kw_not ~ kw_true }
is_false_suffix = { kw_is ~ kw_false }
is_not_false_suffix = { kw_is ~ kw_not ~ kw_false }
is_unknown_suffix = { kw_is ~ kw_unknown }
is_not_unknown_suffix = { kw_is ~ kw_not ~ kw_unknown }
is_distinct_suffix = { kw_is ~ kw_distinct ~ kw_from ~ add_expr }
is_not_distinct_suffix = { kw_is ~ kw_not ~ kw_distinct ~ kw_from ~ add_expr }
is_normalized_suffix = { kw_is ~ kw_not? ~ unicode_normal_form? ~ kw_normalized }
in_expr_list_suffix = { kw_not? ~ kw_in ~ "(" ~ expr_list ~ ")" }
in_subquery_suffix = { kw_not? ~ kw_in ~ "(" ~ select_stmt ~ ")" }
quantified_suffix = { quantified_comp_op ~ (kw_any | kw_all) ~ "(" ~ (select_stmt | expr) ~ ")" }
quantified_comp_op = { "@@" | "&&" | "=" | "<>" | "!=" | "<=" | ">=" | "<" | ">" | "!~" | "~" }
quantified_like_suffix = { kw_not? ~ (kw_ilike | kw_like) ~ (kw_any | kw_all) ~ "(" ~ (select_stmt | expr) ~ ")" }
quantified_similar_suffix = { kw_not? ~ kw_similar ~ kw_to ~ (kw_any | kw_all) ~ "(" ~ (select_stmt | expr) ~ ")" }
like_suffix = { kw_not? ~ (kw_ilike | kw_like) ~ concat_expr ~ escape_clause? }
similar_suffix = { kw_not? ~ kw_similar ~ kw_to ~ concat_expr ~ escape_clause? }
escape_clause = { kw_escape ~ concat_expr }
is_document_suffix = { kw_is ~ kw_not? ~ kw_document }
json_access_op = { "#>>" | "#>" | "->>" | "->" }
comp_op = { "<->" | "##" | "?#" | "?||" | "?-|" | "~=" | "~<=~" | "~>=~" | "~<~" | "~>~" | "^@" | "&<|" | "|&>" | "<<|" | "|>>" | "<<=" | ">>=" | "&<" | "&>" | "<^" | ">^" | "<%" | "?-" | "-|-" | "@>" | "<@" | "@?" | "@@" | "?|" | "?&" | "?" | "&&" | "=" | "<>" | "!=" | "<=" | ">=" | "<" | ">" | "!~" | "~" }
unary_expr = { positive_expr | negated_expr | primary_expr }
postfix_expr = { unary_expr ~ (cast_suffix | subscript_suffix | field_select_suffix | collate_suffix | at_time_zone_suffix | at_local_suffix)* }
cast_suffix = { "::" ~ cast_type_name }
subscript_suffix = { "[" ~ subscript_bound? ~ (":" ~ subscript_bound?)? ~ "]" }
subscript_bound = { expr }
field_select_suffix = { "." ~ (identifier | star) }
collate_suffix = { kw_collate ~ collation_name }
at_local_suffix = { kw_at ~ kw_local }
at_time_zone_suffix = { kw_at ~ kw_time ~ kw_zone ~ postfix_expr }
positive_expr = { "+" ~ unary_expr }
prefix_operator = @{ operator_token }
negated_expr = { prefix_operator ~ unary_expr }
primary_expr = { kw_default | kw_null | kw_true | kw_false | kw_current_date | kw_current_catalog | kw_current_schema | kw_current_user | kw_session_user | kw_current_role | kw_current_time | kw_current_timestamp | kw_localtime | kw_localtimestamp | exists_expr | scalar_subquery_expr | array_subquery_expr | case_expr | array_expr | row_expr | implicit_row_expr | cast_expr | typed_string_literal | extract_expr | normalize_expr | position_expr | substring_expr | overlay_expr | trim_expr | xml_element_expr | xml_forest_expr | xml_parse_expr | xml_pi_expr | xml_root_expr | xml_serialize_expr | func_call | qualified_star | bit_string_literal | quoted_string_literal | identifier | numeric_literal | hex_integer | oct_integer | bin_integer | integer | "(" ~ expr ~ ")" }
case_expr = { kw_case ~ (searched_case_body | simple_case_body) ~ kw_end }
searched_case_body = { when_clause+ ~ else_clause? }
simple_case_body = { expr ~ when_clause+ ~ else_clause? }
when_clause = { kw_when ~ expr ~ kw_then ~ expr }
else_clause = { kw_else ~ expr }
row_expr = { kw_row ~ "(" ~ expr_list? ~ ")" }
implicit_row_expr = { "(" ~ expr ~ ("," ~ expr)+ ~ ")" }
scalar_subquery_expr = { "(" ~ (select_stmt | values_stmt) ~ ")" }
array_subquery_expr = { kw_array ~ "(" ~ (select_stmt | values_stmt) ~ ")" }
exists_expr = { kw_exists ~ "(" ~ select_stmt ~ ")" }
array_expr = { kw_array ~ "[" ~ array_expr_elements? ~ "]" }
array_expr_elements = { array_expr_element ~ ("," ~ array_expr_element)* }
array_expr_element = { nested_array_expr | expr }
nested_array_expr = { "[" ~ array_expr_elements? ~ "]" }
cast_expr = { kw_cast ~ "(" ~ expr ~ kw_as ~ cast_type_name ~ ")" }
cast_type_name = { interval_type ~ interval_field_clause? ~ type_array_suffix* | type_name }
agg_distinct = { kw_distinct_atom }
agg_func = { kw_count | kw_any_value | kw_sum | kw_avg | kw_variance | kw_stddev | kw_min | kw_max | kw_string_agg | kw_array_agg | kw_json_agg | kw_jsonb_agg | kw_json_object_agg | kw_jsonb_object_agg | kw_xmlagg | kw_range_agg | kw_range_intersect_agg }
agg_order_by_clause = { kw_order ~ kw_by ~ order_by_item ~ ("," ~ order_by_item)* }
within_group_clause = { kw_within ~ kw_group ~ "(" ~ agg_order_by_clause ~ ")" }
agg_filter_clause = { kw_filter ~ "(" ~ kw_where ~ expr ~ ")" }
window_partition_by_clause = { kw_partition ~ kw_by ~ expr ~ ("," ~ expr)* }
window_order_by_clause = { kw_order ~ kw_by ~ order_by_item ~ ("," ~ order_by_item)* }
window_frame_bound = { kw_unbounded ~ (kw_preceding | kw_following) | kw_current ~ kw_row | expr ~ (kw_preceding | kw_following) }
window_frame_between = { kw_between ~ window_frame_bound ~ kw_and ~ window_frame_bound }
window_frame_exclusion = { kw_exclude ~ (!")" ~ ANY)* }
window_frame_clause = { (kw_rows | kw_range | kw_groups) ~ (window_frame_between | window_frame_bound) ~ window_frame_exclusion? }
window_ref_name = { !kw_partition_atom ~ !kw_order_atom ~ !kw_rows_atom ~ !kw_range_atom ~ !kw_groups_atom ~ identifier }
raw_window_spec = { window_ref_name? ~ window_partition_by_clause? ~ window_order_by_clause? ~ window_frame_clause? }
empty_window_spec = { "(" ~ ")" }
over_clause = { kw_over ~ (identifier | "(" ~ raw_window_spec ~ ")" | empty_window_spec) }
window_clause = { kw_window ~ window_definition ~ ("," ~ window_definition)* }
window_definition = { identifier ~ kw_as ~ ("(" ~ raw_window_spec ~ ")" | empty_window_spec) }
func_call_name = { agg_func | identifier }
func_call = { func_call_name ~ "(" ~ (agg_distinct ~ function_arg_list ~ agg_order_by_clause? | star | function_arg_list ~ agg_order_by_clause?)? ~ ")" ~ within_group_clause? ~ agg_filter_clause? ~ over_clause? }
function_arg_list = { variadic_function_arg | function_arg ~ ("," ~ function_arg)* ~ ("," ~ variadic_function_arg)? }
function_arg = { named_function_arg | positional_function_arg }
positional_function_arg = { !kw_variadic_atom ~ expr }
variadic_function_arg = { kw_variadic ~ expr }
named_function_arg = { identifier ~ ("=>" | ":=") ~ expr }
position_expr = { ^"position" ~ "(" ~ concat_expr ~ kw_in ~ concat_expr ~ ")" }
substring_expr = { substring_from_expr | substring_for_expr | substring_similar_expr }
substring_from_expr = { ^"substring" ~ "(" ~ expr_until_substring_keyword ~ kw_from ~ expr ~ (kw_for ~ expr)? ~ ")" }
substring_for_expr = { ^"substring" ~ "(" ~ expr_until_substring_keyword ~ kw_for ~ expr ~ ")" }
substring_similar_expr = { ^"substring" ~ "(" ~ expr_until_substring_keyword ~ kw_similar ~ concat_expr ~ escape_clause? ~ ")" }
overlay_expr = { ^"overlay" ~ "(" ~ expr_until_placing ~ kw_placing ~ expr_until_from ~ kw_from ~ expr ~ (kw_for ~ expr)? ~ ")" }
trim_expr = { ^"trim" ~ "(" ~ trim_variant ~ ")" }
xml_element_expr = { ^"xmlelement" ~ "(" ~ kw_name ~ identifier ~ ("," ~ xml_element_arg ~ ("," ~ xml_element_arg)*)? ~ ")" }
xml_element_arg = { xml_attributes_expr | expr }
xml_attributes_expr = { ^"xmlattributes" ~ "(" ~ xml_attribute_item ~ ("," ~ xml_attribute_item)* ~ ")" }
xml_attribute_item = { expr ~ (kw_as ~ identifier)? }
xml_forest_expr = { ^"xmlforest" ~ "(" ~ xml_forest_item ~ ("," ~ xml_forest_item)* ~ ")" }
xml_forest_item = { expr ~ (kw_as ~ identifier)? }
xml_parse_expr = { ^"xmlparse" ~ "(" ~ (kw_document | kw_content) ~ expr ~ (kw_preserve ~ kw_whitespace)? ~ ")" }
xml_pi_expr = { ^"xmlpi" ~ "(" ~ kw_name ~ identifier ~ ("," ~ expr)? ~ ")" }
xml_root_expr = { ^"xmlroot" ~ "(" ~ expr ~ "," ~ kw_version ~ xml_root_version ~ ("," ~ kw_standalone ~ xml_root_standalone)? ~ ")" }
xml_root_version = { kw_no ~ kw_value | expr }
xml_root_standalone = { kw_yes | kw_no | kw_no ~ kw_value }
xml_serialize_expr = { ^"xmlserialize" ~ "(" ~ (kw_document | kw_content) ~ expr ~ kw_as ~ type_name ~ ((kw_no ~ kw_indent) | kw_indent)? ~ ")" }
extract_expr = { ^"extract" ~ "(" ~ extract_field ~ kw_from ~ expr ~ ")" }
normalize_expr = { ^"normalize" ~ "(" ~ expr ~ ("," ~ unicode_normal_form)? ~ ")" }
unicode_normal_form = { kw_nfc | kw_nfd | kw_nfkc | kw_nfkd }
extract_field = { identifier | quoted_string_literal }
trim_variant = { trim_spec_chars_from | trim_spec_from | trim_chars_from | trim_source_only }
trim_spec_chars_from = { trim_spec ~ expr ~ kw_from ~ expr }
trim_spec_from = { trim_spec ~ kw_from ~ expr }
trim_chars_from = { expr ~ kw_from ~ expr }
trim_source_only = { expr }
trim_spec = { kw_both | kw_leading | kw_trailing }
typed_string_literal = { interval_string_literal | !escape_string_literal ~ !bit_string_literal ~ type_name ~ quoted_string_literal }
interval_string_literal = { interval_type ~ quoted_string_literal ~ interval_field_clause? }
interval_field_clause = { interval_field ~ (kw_to ~ interval_field)? ~ ("(" ~ integer ~ ")")? }
interval_field = { kw_year | kw_month | kw_day | kw_hour | kw_minute | kw_second }
expr_until_substring_keyword = @{ (!(kw_from_atom | kw_for_atom | kw_similar_atom) ~ ANY)+ }
expr_until_from = @{ (!kw_from_atom ~ ANY)+ }
expr_until_placing = @{ (!kw_placing_atom ~ ANY)+ }

ident_cont = _{ ASCII_ALPHANUMERIC | "_" | "." }
keyword_end = _{ !ident_cont }
identifier = { unicode_quoted_identifier | quoted_identifier | unquoted_identifier }
unquoted_identifier = @{ (ASCII_ALPHA | "_") ~ ident_cont* }
quoted_identifier = @{ "\"" ~ ("\"\"" | !("\"") ~ ANY)* ~ "\"" }
unicode_quoted_identifier = { unicode_identifier_prefix ~ quoted_identifier ~ unicode_escape_clause? }
unicode_identifier_prefix = @{ ^"u&" }
collation_name = { identifier ~ ("." ~ identifier)? }
simple_identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
dec_integer = @{ ASCII_DIGIT ~ ("_"? ~ ASCII_DIGIT)* }
numeric_literal = @{
    (dec_integer ~ "." ~ !"." ~ dec_integer? ~ exponent?)
    | ("." ~ dec_integer ~ exponent?)
    | (dec_integer ~ exponent)
}
integer = @{ dec_integer }
hex_integer = @{ ^"0x" ~ ("_"? ~ ASCII_HEX_DIGIT)+ }
oct_digit = _{ "0" | "1" | "2" | "3" | "4" | "5" | "6" | "7" }
oct_integer = @{ ^"0o" ~ ("_"? ~ oct_digit)+ }
bin_digit = _{ "0" | "1" }
bin_integer = @{ ^"0b" ~ ("_"? ~ bin_digit)+ }
signed_integer = @{ ("+" | "-")? ~ ASCII_DIGIT+ }
exponent = _{ ("e" | "E") ~ ("+" | "-")? ~ dec_integer }
quoted_string_literal = _{ unicode_string_literal | escape_string_literal | dollar_string_literal | string_literal }
string_literal = @{ "'" ~ ( "''" | (!"'" ~ ANY) )* ~ "'" }
escape_string_literal = @{ ^"e" ~ string_literal }
unicode_string_literal = { unicode_string_prefix ~ string_literal ~ unicode_escape_clause? }
unicode_string_prefix = @{ ^"u&" }
unicode_escape_clause = { kw_uescape ~ string_literal }
bit_string_literal = { binary_bit_literal | hex_bit_literal }
binary_bit_literal = @{ ^"b" ~ string_literal }
hex_bit_literal = @{ ^"x" ~ string_literal }
dollar_string_literal = @{ dollar_quote_start ~ dollar_string_body ~ dollar_quote_end }
dollar_quote_start = ${ "$" ~ PUSH(identifier?) ~ "$" }
dollar_quote_end = ${ "$" ~ POP ~ "$" }
dollar_string_body = { (!( "$" ~ PEEK ~ "$") ~ ANY)* }
star = { "*" }
qualified_star = { simple_identifier ~ "." ~ star }

