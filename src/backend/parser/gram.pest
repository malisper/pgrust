WHITESPACE = _{ " " | "\t" | "\r" | "\n" }

statement = { SOI ~ stmt ~ EOI }
stmt = _{ do_stmt | call_stmt | explain_stmt | declare_cursor_stmt | fetch_stmt | move_stmt | close_portal_stmt | table_stmt | select_into_stmt | select_stmt | values_stmt | copy_stmt | analyze_stmt | checkpoint_stmt | notify_stmt | listen_stmt | unlisten_stmt | show_stmt | set_session_authorization_stmt | reset_session_authorization_stmt | set_role_stmt | reset_role_stmt | set_transaction_stmt | set_stmt | reset_stmt | create_role_stmt | alter_role_stmt | alter_group_stmt | create_database_stmt | alter_database_stmt | create_schema_stmt | create_policy_stmt | create_index_stmt | alter_table_add_column_stmt | alter_table_add_constraint_stmt | alter_table_drop_constraint_stmt | alter_table_alter_constraint_stmt | alter_table_rename_constraint_stmt | alter_table_drop_column_stmt | alter_table_alter_column_type_stmt | alter_table_alter_column_expression_stmt | alter_table_alter_column_default_stmt | alter_table_alter_column_compression_stmt | alter_table_alter_column_storage_stmt | alter_table_alter_column_options_stmt | alter_table_alter_column_statistics_stmt | alter_table_owner_stmt | alter_table_rename_column_stmt | alter_table_rename_stmt | alter_table_set_schema_stmt | alter_view_owner_stmt | alter_view_rename_column_stmt | alter_view_set_schema_stmt | alter_schema_owner_stmt | alter_table_set_stmt | alter_table_reset_stmt | alter_table_set_row_security_stmt | alter_policy_stmt | alter_table_set_not_null_stmt | alter_table_drop_not_null_stmt | alter_table_validate_constraint_stmt | alter_table_inherit_stmt | alter_table_no_inherit_stmt | alter_table_of_stmt | alter_table_not_of_stmt | comment_on_role_stmt | comment_on_table_stmt | comment_on_view_stmt | comment_on_index_stmt | comment_on_rule_stmt | comment_on_trigger_stmt | create_table_stmt | create_materialized_view_stmt | create_view_stmt | create_rule_stmt | refresh_materialized_view_stmt | drop_role_stmt | drop_database_stmt | drop_table_stmt | drop_index_stmt | drop_materialized_view_stmt | drop_view_stmt | drop_rule_stmt | drop_policy_stmt | drop_schema_stmt | drop_owned_stmt | reassign_owned_stmt | truncate_table_stmt | vacuum_stmt | insert_stmt | merge_stmt | update_stmt | delete_stmt | begin_stmt | commit_stmt | rollback_to_stmt | rollback_stmt | savepoint_stmt }

do_stmt = { kw_do ~ do_body ~ do_language_clause? | kw_do ~ do_language_clause ~ do_body }
do_body = { quoted_string_literal }
do_language_clause = { kw_language ~ identifier }
call_stmt = { kw_call ~ identifier ~ ("." ~ identifier)? ~ "(" ~ function_arg_list? ~ ")" }

analyze_stmt = { kw_analyze ~ analyze_option_block? ~ maintenance_target_list? }
checkpoint_stmt = { kw_checkpoint }
notify_stmt = { kw_notify ~ identifier ~ notify_payload? }
notify_payload = { "," ~ quoted_string_literal }
listen_stmt = { kw_listen ~ identifier }
unlisten_stmt = { kw_unlisten ~ (identifier | "*") }
show_stmt = { kw_show ~ (show_transaction_isolation_clause | time_zone_guc_name | identifier) }
show_transaction_isolation_clause = { kw_transaction ~ kw_isolation ~ kw_level }
declare_cursor_stmt = { kw_declare ~ identifier ~ cursor_option* ~ kw_cursor ~ cursor_hold_clause? ~ kw_for ~ select_stmt }
cursor_option = { kw_binary | kw_insensitive | kw_no ~ kw_scroll | kw_scroll }
cursor_hold_clause = { kw_with ~ kw_hold | kw_without ~ kw_hold }
fetch_stmt = { kw_fetch ~ fetch_direction? ~ fetch_portal_name }
move_stmt = { kw_move ~ fetch_direction? ~ fetch_portal_name }
fetch_portal_name = { (kw_from | kw_in)? ~ identifier }
fetch_direction = { (kw_forward | kw_backward) ~ fetch_count? | kw_absolute ~ signed_integer | kw_relative ~ signed_integer | kw_next | kw_prior | kw_first | kw_last | fetch_count }
fetch_count = { kw_all | signed_integer }
close_portal_stmt = { kw_close ~ (kw_all | identifier) }
explain_stmt = { kw_explain ~ (kw_analyze | "(" ~ explain_option ~ ("," ~ explain_option)* ~ ")")? ~ (select_stmt | insert_stmt | merge_stmt | update_stmt | delete_stmt) }
explain_option = { explain_option_name ~ explain_option_value? }
explain_option_name = { kw_analyze | kw_buffers | kw_costs | kw_timing | kw_verbose | kw_summary | kw_format }
explain_option_value = { kw_off | kw_true | kw_false | kw_text | kw_json | kw_yaml | kw_xml | kw_on_value }
select_stmt = { set_operation_stmt | simple_select_stmt }
select_into_stmt = {
    cte_clause? ~ select_into_core ~ window_clause? ~ order_by_clause? ~ limit_clause? ~ offset_clause? ~ locking_clause?
  | cte_clause? ~ select_into_core ~ window_clause? ~ order_by_clause? ~ locking_clause ~ limit_clause? ~ offset_clause?
}
simple_select_stmt = {
    cte_clause? ~ simple_select_core ~ window_clause? ~ order_by_clause? ~ limit_clause? ~ offset_clause? ~ locking_clause?
  | cte_clause? ~ simple_select_core ~ window_clause? ~ order_by_clause? ~ locking_clause ~ limit_clause? ~ offset_clause?
}
select_into_core = { kw_select ~ select_distinct_clause? ~ (empty_select_list | select_list)? ~ kw_into ~ select_into_target ~ (kw_from ~ from_item)? ~ (kw_where ~ expr)? ~ group_by_clause? ~ having_clause? }
simple_select_core = { kw_select ~ select_distinct_clause? ~ (empty_select_list | select_list)? ~ (kw_from ~ from_item)? ~ (kw_where ~ expr)? ~ group_by_clause? ~ having_clause? }
select_into_target = { temp_clause? ~ kw_table? ~ identifier }
select_distinct_clause = { kw_distinct ~ (kw_on ~ "(" ~ expr ~ ("," ~ expr)* ~ ")")? }
set_operation_stmt = {
    cte_clause? ~ set_operation_term ~ (set_operation_clause ~ set_operation_term)+ ~ window_clause? ~ order_by_clause? ~ limit_clause? ~ offset_clause? ~ locking_clause?
  | cte_clause? ~ set_operation_term ~ (set_operation_clause ~ set_operation_term)+ ~ window_clause? ~ order_by_clause? ~ locking_clause ~ limit_clause? ~ offset_clause?
}
set_operation_term = { parenthesized_set_operation_term | simple_select_core }
parenthesized_set_operation_term = { "(" ~ (select_stmt | parenthesized_set_operation_term) ~ ")" }
set_operation_clause = { (kw_union | kw_intersect | kw_except) ~ kw_all? }
values_stmt = { cte_clause? ~ kw_values ~ values_row ~ ("," ~ values_row)* ~ order_by_clause? ~ limit_clause? ~ offset_clause? }
copy_stmt = { ^"copy" ~ identifier ~ ("(" ~ ident_list ~ ")")? ~ kw_from ~ quoted_string_literal }
cte_clause = { kw_with ~ kw_recursive? ~ common_table_expr ~ ("," ~ common_table_expr)* }
common_table_expr = { identifier ~ cte_column_list? ~ kw_as ~ "(" ~ cte_body ~ ")" }
cte_column_list = { "(" ~ ident_list ~ ")" }
cte_body = { recursive_union_cte_body | select_stmt | values_stmt }
recursive_union_cte_body = { (simple_select_stmt | values_stmt) ~ kw_union ~ kw_all? ~ (parenthesized_set_operation_term | select_stmt) }
empty_select_list = { &kw_from }
group_by_clause = { kw_group ~ kw_by ~ expr ~ ("," ~ expr)* }
having_clause = { kw_having ~ expr }
order_by_clause = { kw_order ~ kw_by ~ order_by_item ~ ("," ~ order_by_item)* }
operator_token = @{ ("!" | "#" | "%" | "&" | "*" | "+" | "-" | "/" | "<" | "=" | ">" | "?" | "@" | "^" | "|" | "~")+ }
order_by_item = { expr ~ ((kw_using ~ operator_token) | (kw_asc | kw_desc))? ~ nulls_ordering? }
nulls_ordering = { kw_nulls ~ (kw_first | kw_last) }
limit_clause = { kw_limit ~ (integer | kw_null) }
offset_clause = { kw_offset ~ integer }
locking_clause = { kw_for ~ ((kw_no ~ kw_key ~ kw_update) | (kw_key ~ kw_share) | kw_update | kw_share) ~ locking_of_clause? }
locking_of_clause = { kw_of ~ identifier ~ ("," ~ identifier)* }
set_stmt = { kw_set ~ set_scope? ~ (set_time_zone_clause | set_xml_option_clause | set_standard_clause) }
set_transaction_stmt = { kw_set ~ ((kw_transaction ~ transaction_mode_list) | (kw_session ~ kw_characteristics ~ kw_as ~ kw_transaction ~ transaction_mode_list)) }
reset_stmt = { kw_reset ~ (kw_all | time_zone_guc_name | identifier) }
set_session_authorization_stmt = { kw_set ~ kw_session ~ kw_authorization ~ session_authorization_target }
reset_session_authorization_stmt = { kw_reset ~ kw_session ~ kw_authorization }
set_role_stmt = { kw_set ~ kw_role ~ (kw_none | identifier) }
reset_role_stmt = { kw_reset ~ kw_role }
session_authorization_target = { identifier | quoted_string_literal }
set_scope = { kw_session | kw_local }
set_standard_clause = { identifier ~ (("=" | kw_to) ~ set_value_list) }
set_time_zone_clause = { time_zone_guc_name ~ ((("=" | kw_to) ~ set_value_list) | set_value_list) }
set_xml_option_clause = { kw_xml ~ kw_option ~ (kw_document | kw_content) }
time_zone_guc_name = { kw_time ~ kw_zone }
set_value_list = { set_value_atom ~ ("," ~ set_value_atom)* }
set_value_atom = { signed_set_value | kw_default | kw_true | kw_false | kw_on_value | kw_off | quoted_string_literal | identifier | numeric_literal | integer }
signed_set_value = { ("+" | "-") ~ (numeric_literal | integer | identifier) }

insert_stmt = { cte_clause? ~ kw_insert ~ kw_into ~ identifier ~ insert_target_alias? ~ ("(" ~ assignment_target_list ~ ")")? ~ insert_overriding_clause? ~ (insert_values_source | insert_default_values_source | select_stmt) ~ on_conflict_clause? ~ returning_clause? }
insert_target_alias = { kw_as? ~ insert_alias_identifier }
insert_alias_identifier = { !kw_values_atom ~ !kw_default_atom ~ !kw_select_atom ~ !kw_overriding_atom ~ identifier }
insert_overriding_clause = { kw_overriding ~ (kw_system | kw_user) ~ kw_value }
insert_values_source = { kw_values ~ values_row ~ ("," ~ values_row)* }
insert_default_values_source = { kw_default ~ kw_values }
merge_stmt = { cte_clause? ~ kw_merge ~ kw_into ~ merge_target ~ kw_using ~ merge_source ~ merge_join_condition ~ merge_when_clause+ }
merge_target = { only_clause? ~ identifier ~ merge_target_alias? }
merge_target_alias = { kw_as? ~ merge_alias_identifier }
merge_source = { aliased_from_item }
merge_alias_identifier = { !kw_on ~ !kw_using ~ !kw_when ~ !kw_matched ~ !kw_then ~ !kw_insert ~ !kw_update ~ !kw_delete ~ !kw_do ~ !kw_nothing ~ !kw_source ~ !kw_target ~ identifier }
update_target = { only_clause? ~ identifier ~ update_target_alias? }
update_target_alias = { kw_as? ~ update_alias_identifier }
update_alias_identifier = { !kw_set_atom ~ !kw_from_atom ~ !kw_where_atom ~ !kw_returning_atom ~ identifier }
merge_join_condition = { kw_on ~ expr }
merge_when_clause = { merge_when_not_matched_by_source_clause | merge_when_not_matched_by_target_clause | merge_when_not_matched_clause | merge_when_matched_clause }
merge_when_matched_clause = { kw_when ~ kw_matched ~ merge_search_condition? ~ kw_then ~ merge_matched_action }
merge_when_not_matched_by_source_clause = { kw_when ~ kw_not ~ kw_matched ~ kw_by ~ kw_source ~ merge_search_condition? ~ kw_then ~ merge_matched_action }
merge_when_not_matched_clause = { kw_when ~ kw_not ~ kw_matched ~ merge_search_condition? ~ kw_then ~ merge_not_matched_action }
merge_when_not_matched_by_target_clause = { kw_when ~ kw_not ~ kw_matched ~ kw_by ~ kw_target ~ merge_search_condition? ~ kw_then ~ merge_not_matched_action }
merge_search_condition = { kw_and ~ expr }
merge_matched_action = { merge_update_action | merge_delete_action | merge_do_nothing_action }
merge_not_matched_action = { merge_insert_action | merge_do_nothing_action }
merge_update_action = { kw_update ~ kw_set ~ assignment ~ ("," ~ assignment)* }
merge_delete_action = { kw_delete }
merge_do_nothing_action = { kw_do ~ kw_nothing }
merge_insert_action = { kw_insert ~ merge_insert_columns? ~ (merge_insert_values_source | merge_insert_default_values_source) }
merge_insert_columns = { "(" ~ ident_list ~ ")" }
merge_insert_values_source = { kw_values ~ values_row }
merge_insert_default_values_source = { kw_default ~ kw_values }
on_conflict_clause = { kw_on ~ kw_conflict ~ (on_conflict_do_nothing | on_conflict_do_update) }
on_conflict_do_nothing = { on_conflict_target? ~ kw_do ~ kw_nothing }
on_conflict_do_update = { on_conflict_target? ~ kw_do ~ kw_update ~ kw_set ~ assignment ~ ("," ~ assignment)* ~ (kw_where ~ expr)? }
on_conflict_target = { on_conflict_constraint_target | on_conflict_inference_target }
on_conflict_constraint_target = { kw_on ~ kw_constraint ~ identifier }
on_conflict_inference_target = { "(" ~ on_conflict_inference_elem ~ ("," ~ on_conflict_inference_elem)* ~ ")" ~ on_conflict_inference_predicate? }
on_conflict_inference_predicate = { kw_where ~ expr }
on_conflict_inference_elem = { on_conflict_inference_expr ~ on_conflict_inference_collation? ~ on_conflict_inference_opclass? }
on_conflict_inference_expr = { expr }
on_conflict_inference_collation = { kw_collate ~ collation_name }
on_conflict_inference_opclass = { create_index_opclass }
create_role_stmt = { kw_create ~ (kw_role | kw_user | kw_group) ~ identifier ~ (kw_with ~ role_option*)? ~ role_option* }
alter_role_stmt = { kw_alter ~ (kw_role | kw_user) ~ identifier ~ (alter_role_rename_clause | (kw_with? ~ alter_role_option+)) }
alter_group_stmt = { kw_alter ~ kw_group ~ identifier ~ alter_group_action }
alter_group_action = { (kw_add | kw_drop) ~ kw_user ~ ident_list }
alter_role_rename_clause = { kw_rename ~ kw_to ~ identifier }
create_database_stmt = { kw_create ~ kw_database ~ identifier ~ kw_with? ~ create_database_options? }
create_database_options = { create_database_option+ }
create_database_option = { create_database_connection_limit_option | create_database_simple_option }
create_database_simple_option = { identifier ~ opt_equal ~ create_database_option_value }
create_database_connection_limit_option = { kw_connection ~ kw_limit ~ opt_equal ~ signed_integer }
create_database_option_value = { signed_integer | kw_default | kw_true | kw_false | kw_on_value | kw_off | quoted_string_literal | identifier }
opt_equal = _{ "="? }
alter_database_stmt = { kw_alter ~ kw_database ~ identifier ~ alter_database_action }
alter_database_action = { alter_database_rename_action | alter_database_set_tablespace_action | alter_database_reset_tablespace_action | alter_database_connection_limit_action | alter_database_owner_action }
alter_database_rename_action = { kw_rename ~ kw_to ~ identifier }
alter_database_set_tablespace_action = { kw_set ~ identifier ~ identifier }
alter_database_reset_tablespace_action = { kw_reset ~ identifier }
alter_database_connection_limit_action = { identifier ~ signed_integer }
alter_database_owner_action = { kw_owner ~ kw_to ~ identifier }
create_schema_stmt = { kw_create ~ kw_schema ~ (if_not_exists_clause ~ identifier ~ create_schema_authorization_clause? | create_schema_authorization_only | identifier ~ create_schema_authorization_clause?) }
create_policy_stmt = { kw_create ~ kw_policy ~ (!EOI ~ ANY)+ }
create_schema_authorization_clause = { kw_authorization ~ identifier }
create_schema_authorization_only = { kw_authorization ~ identifier }
create_table_stmt = { kw_create ~ temp_clause? ~ kw_table ~ if_not_exists_clause? ~ identifier ~ create_table_tail ~ inherits_clause? ~ table_storage_clause? }
create_materialized_view_stmt = { kw_create ~ kw_materialized ~ kw_view ~ if_not_exists_clause? ~ identifier ~ create_matview_column_list? ~ kw_as ~ select_stmt ~ matview_data_clause? }
create_matview_column_list = { "(" ~ ident_list ~ ")" }
matview_data_clause = { kw_with ~ kw_no? ~ kw_data }
create_view_stmt = { kw_create ~ create_or_replace_clause? ~ temp_clause? ~ kw_view ~ identifier ~ view_options_clause? ~ kw_as ~ select_stmt ~ view_check_option_clause? }
view_options_clause = { kw_with ~ "(" ~ view_reloption ~ ("," ~ view_reloption)* ~ ")" }
view_reloption = { identifier ~ ("=" ~ set_value_atom)? }
create_or_replace_clause = { kw_or ~ kw_replace }
view_check_option_clause = { kw_with ~ (kw_local | kw_cascaded)? ~ kw_check ~ kw_option }
create_rule_stmt = { kw_create ~ kw_rule ~ identifier ~ kw_as ~ kw_on ~ rule_event ~ kw_to ~ identifier ~ rule_where_clause? ~ kw_do ~ rule_do_kind? ~ rule_action_body }
create_index_stmt = { kw_create ~ kw_unique? ~ kw_index ~ kw_concurrently? ~ if_not_exists_clause? ~ create_index_name? ~ kw_on ~ only_clause? ~ identifier ~ create_index_using_clause? ~ "(" ~ create_index_item ~ ("," ~ create_index_item)* ~ ")" ~ create_index_include_clause? ~ unique_nulls_not_distinct_clause? ~ create_index_where_clause? ~ create_index_with_clause? }
create_index_name = { !(kw_on_atom | kw_concurrently_atom) ~ identifier }
create_index_using_clause = { kw_using ~ identifier }
create_index_item = { create_index_target ~ create_index_opclass? ~ (kw_asc | kw_desc)? ~ nulls_ordering? }
create_index_target = { create_index_expression | create_index_function_expression | identifier }
create_index_expression = { "(" ~ expr ~ ")" }
create_index_function_expression = { func_call }
create_index_opclass = { !kw_asc_atom ~ !kw_desc_atom ~ !kw_nulls_atom ~ identifier }
create_index_include_clause = { kw_include ~ "(" ~ ident_list ~ ")" }
create_index_where_clause = { kw_where ~ expr }
create_index_with_clause = { kw_with ~ "(" ~ reloption ~ ("," ~ reloption)* ~ ")" }
alter_table_target = { if_exists_clause? ~ (only_clause ~ identifier | identifier ~ star?) }
alter_table_add_column_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_add ~ kw_column? ~ column_def }
alter_table_add_constraint_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_add ~ (alter_table_add_using_index_constraint | table_constraint) }
alter_table_add_using_index_constraint = { (kw_constraint ~ identifier)? ~ (kw_primary ~ kw_key | kw_unique) ~ kw_using ~ kw_index ~ identifier ~ constraint_attribute* }
alter_table_drop_column_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_drop ~ !kw_constraint ~ kw_column? ~ identifier }
alter_table_drop_constraint_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_drop ~ kw_constraint ~ identifier }
alter_table_alter_constraint_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_constraint ~ identifier ~ alter_table_constraint_action }
alter_table_constraint_action = { alter_table_constraint_attribute+ }
alter_table_constraint_attribute = _{ deferrable_constraint_attribute | not_deferrable_constraint_attribute | initially_deferred_constraint_attribute | initially_immediate_constraint_attribute | enforced_constraint_attribute | not_enforced_constraint_attribute }
alter_table_rename_constraint_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_rename ~ kw_constraint ~ identifier ~ kw_to ~ identifier }
alter_table_alter_column_type_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ alter_table_column_type_action }
alter_table_alter_column_expression_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ alter_table_column_expression_action }
alter_table_alter_column_default_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ alter_table_column_default_action }
alter_table_alter_column_compression_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ kw_set ~ kw_compression ~ (kw_default | identifier) }
alter_table_alter_column_storage_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ kw_set ~ kw_storage ~ identifier }
alter_table_alter_column_options_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ alter_table_column_options_action }
alter_table_alter_column_statistics_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ kw_set ~ kw_statistics ~ signed_integer }
alter_table_owner_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_owner ~ kw_to ~ identifier }
alter_table_column_type_action = { (kw_type | (kw_set ~ kw_data ~ kw_type)) ~ type_name ~ alter_table_using_clause? }
alter_table_column_expression_action = { alter_table_set_expression_action | alter_table_drop_expression_action }
alter_table_column_default_action = { alter_table_set_default_action | alter_table_drop_default_action }
alter_table_column_options_action = { alter_table_set_options_action | alter_table_reset_options_action }
alter_table_set_expression_action = { kw_set ~ kw_expression ~ kw_as ~ "(" ~ expr ~ ")" }
alter_table_drop_expression_action = { kw_drop ~ kw_expression ~ if_exists_clause? }
alter_table_set_default_action = { kw_set ~ kw_default ~ expr }
alter_table_drop_default_action = { kw_drop ~ kw_default }
alter_table_set_options_action = { kw_set ~ "(" ~ reloption ~ ("," ~ reloption)* ~ ")" }
alter_table_reset_options_action = { kw_reset ~ "(" ~ ident_list ~ ")" }
alter_table_using_clause = { kw_using ~ expr }
alter_table_rename_column_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_rename ~ kw_column ~ identifier ~ kw_to ~ identifier }
alter_table_rename_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_rename ~ kw_to ~ identifier }
alter_table_set_schema_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_set ~ kw_schema ~ identifier }
alter_view_owner_stmt = { kw_alter ~ kw_view ~ identifier ~ kw_owner ~ kw_to ~ identifier }
alter_view_rename_column_stmt = { kw_alter ~ kw_view ~ alter_view_target ~ kw_rename ~ kw_column ~ identifier ~ kw_to ~ identifier }
alter_view_set_schema_stmt = { kw_alter ~ kw_view ~ alter_view_target ~ kw_set ~ kw_schema ~ identifier }
alter_schema_owner_stmt = { kw_alter ~ kw_schema ~ identifier ~ kw_owner ~ kw_to ~ identifier }
alter_table_set_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_set ~ "(" ~ reloption ~ ("," ~ reloption)* ~ ")" }
alter_table_reset_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_reset ~ "(" ~ ident_list ~ ")" }
alter_table_set_row_security_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ alter_table_row_security_action }
alter_view_target = { if_exists_clause? ~ identifier }
alter_table_row_security_action = { (kw_enable ~ kw_row ~ kw_level ~ kw_security) | (kw_disable ~ kw_row ~ kw_level ~ kw_security) | (kw_force ~ kw_row ~ kw_level ~ kw_security) | (kw_no ~ kw_force ~ kw_row ~ kw_level ~ kw_security) }
alter_policy_stmt = { kw_alter ~ kw_policy ~ (!EOI ~ ANY)+ }
alter_table_set_not_null_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ kw_set ~ kw_not ~ kw_null }
alter_table_drop_not_null_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_alter ~ kw_column? ~ identifier ~ kw_drop ~ kw_not ~ kw_null }
alter_table_validate_constraint_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_validate ~ kw_constraint ~ identifier }
alter_table_inherit_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_inherit ~ identifier }
alter_table_no_inherit_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_no ~ kw_inherit ~ identifier }
alter_table_of_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_of ~ identifier }
alter_table_not_of_stmt = { kw_alter ~ kw_table ~ alter_table_target ~ kw_not ~ kw_of }
drop_role_stmt = { kw_drop ~ (kw_role | kw_user) ~ if_exists_clause? ~ ident_list }
drop_database_stmt = { kw_drop ~ kw_database ~ if_exists_clause? ~ identifier }
comment_on_role_stmt = { kw_comment ~ kw_on ~ kw_role ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
comment_on_table_stmt = { kw_comment ~ kw_on ~ kw_table ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
comment_on_view_stmt = { kw_comment ~ kw_on ~ kw_view ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
comment_on_index_stmt = { kw_comment ~ kw_on ~ kw_index ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
comment_on_rule_stmt = { kw_comment ~ kw_on ~ kw_rule ~ identifier ~ kw_on ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
comment_on_trigger_stmt = { kw_comment ~ kw_on ~ kw_trigger ~ identifier ~ kw_on ~ identifier ~ kw_is ~ (quoted_string_literal | kw_null) }
